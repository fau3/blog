---
import { getCollection } from "astro:content";

import Note from "@/components/note/Note.astro";
import PageLayout from "@/layouts/Base.astro";
import { getEntryDescription } from "@/utils/content-preview";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
export const prerender = true;

export const getStaticPaths = (async () => {
	const allNotes = await getCollection("noteEn");
	return allNotes.map((note) => ({
		params: { slug: note.id },
		props: { note },
	}));
}) satisfies GetStaticPaths;

export type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { note } = Astro.props;
const hasMeting = note.body?.includes("<meting-js") ?? false;

const meta = {
	description: getEntryDescription({
		body: note.body ?? "",
		description: note.data.description,
		maxLength: 160,
	}),
	title: note.data.title,
};
---

<PageLayout meta={meta} hasMeting={hasMeting}>
	<Note as="h1" note={note} locale="en" />
</PageLayout>
