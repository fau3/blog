---
import { ClientRouter } from "astro:transitions";
import BaseHead from "@/components/BaseHead.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	hasMeting?: boolean;
	meta: SiteMeta;
}

const {
	hasMeting = false,
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html class="scroll-smooth" lang={siteConfig.lang}>
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
		<ClientRouter />
		<slot name="head" />
		{
			hasMeting && (
				<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aplayer/dist/APlayer.min.css" />
			)
		}
		<script is:inline>
			(() => {
				const APPLAYER_SCRIPT_ID = "aplayer-script";
				const METING_SCRIPT_ID = "meting-script";

				const loadScriptOnce = (id, src) =>
					new Promise((resolve, reject) => {
						const existing = document.getElementById(id);
						if (existing) {
							if (existing.dataset.loaded === "true") return resolve(existing);
							existing.addEventListener("load", () => resolve(existing), { once: true });
							existing.addEventListener("error", reject, { once: true });
							return;
						}

						const script = document.createElement("script");
						script.id = id;
						script.src = src;
						script.async = true;
						script.crossOrigin = "anonymous";
						script.addEventListener(
							"load",
							() => {
								script.dataset.loaded = "true";
								resolve(script);
							},
							{ once: true },
						);
						script.addEventListener("error", reject, { once: true });
						document.head.appendChild(script);
					});

				const patchAPlayer = () => {
					if (window.__fftAPlayerPatched === "true") return;

					const NativeAPlayer = window.APlayer;
					if (typeof NativeAPlayer !== "function") return;

					const isLyricUrl = (value) => {
						if (typeof value !== "string") return false;

						const lyric = value.trim();
						if (!lyric) return false;

						return (
							/^(https?:)?\/\//.test(lyric) ||
							lyric.startsWith("/") ||
							lyric.startsWith("./") ||
							lyric.startsWith("../")
						);
					};

					function PatchedAPlayer(options = {}) {
						const audio = Array.isArray(options.audio) ? options.audio : [];
						const hasInlineLyrics = audio.some((track) => {
							const lyric = typeof track?.lrc === "string" ? track.lrc.trim() : "";
							return lyric && !isLyricUrl(lyric);
						});

						const nextOptions =
							options.lrcType === 3 && hasInlineLyrics ? { ...options, lrcType: 1 } : options;

						return new NativeAPlayer(nextOptions);
					}

					PatchedAPlayer.prototype = NativeAPlayer.prototype;
					Object.setPrototypeOf(PatchedAPlayer, NativeAPlayer);
					window.APlayer = PatchedAPlayer;
					window.__fftAPlayerPatched = "true";
				};

				const ensureMetingAssets = () => {
					if (window.__fftMetingAssetsPromise) return window.__fftMetingAssetsPromise;

					window.meting_api = "/api/meting?server=:server&type=:type&id=:id&r=:r";
					window.__fftMetingAssetsPromise = loadScriptOnce(
						APPLAYER_SCRIPT_ID,
						"https://cdn.jsdelivr.net/npm/aplayer/dist/APlayer.min.js",
					)
						.then(() => {
							patchAPlayer();
							return loadScriptOnce(
								METING_SCRIPT_ID,
								"https://cdn.jsdelivr.net/npm/meting@2/dist/Meting.min.js",
							);
						})
						.then(() => {
							document.dispatchEvent(new CustomEvent("meting:ready"));
						});

					return window.__fftMetingAssetsPromise;
				};

				const scheduleMetingLoad = () => {
					const players = Array.from(document.querySelectorAll("meting-js"));
					if (!players.length) return;

					if (customElements.get("meting-js")) {
						document.dispatchEvent(new CustomEvent("meting:ready"));
						return;
					}

					if (!("IntersectionObserver" in window)) {
						ensureMetingAssets().catch((error) => {
							console.error("Failed to load music player assets", error);
						});
						return;
					}

					window.__fftMetingObserver?.disconnect?.();

					const observer = new IntersectionObserver(
						(entries) => {
							if (entries.some((entry) => entry.isIntersecting)) {
								observer.disconnect();
								ensureMetingAssets().catch((error) => {
									console.error("Failed to load music player assets", error);
								});
							}
						},
						{ rootMargin: "1200px 0px" },
					);

					players.forEach((player) => observer.observe(player));
					window.__fftMetingObserver = observer;
				};

				scheduleMetingLoad();

				if (window.__fftMetingLoadBound !== "true") {
					window.__fftMetingLoadBound = "true";
					document.addEventListener("astro:page-load", scheduleMetingLoad);
				}
			})();
		</script>
		<style is:global>
			:root[data-theme="dark"] .aplayer {
				background: hsl(var(--theme-muted));
				border: 1px solid hsl(var(--theme-border));
				box-shadow: 0 12px 30px rgb(0 0 0 / 0.28);
			}

			:root[data-theme="dark"] .aplayer .aplayer-info {
				border-bottom-color: hsl(var(--theme-border));
			}

			:root[data-theme="dark"] .aplayer .aplayer-info .aplayer-controller .aplayer-bar-wrap {
				padding-block: 0.25rem;
			}

			:root[data-theme="dark"]
				.aplayer
				.aplayer-info
				.aplayer-controller
				.aplayer-bar-wrap
				.aplayer-bar,
			:root[data-theme="dark"]
				.aplayer
				.aplayer-info
				.aplayer-controller
				.aplayer-volume-wrap
				.aplayer-volume-bar-wrap {
				background: hsl(var(--theme-border));
				box-shadow: none;
			}

			:root[data-theme="dark"]
				.aplayer
				.aplayer-info
				.aplayer-controller
				.aplayer-bar-wrap
				.aplayer-bar
				.aplayer-loaded {
				background: hsl(var(--theme-text) / 0.18);
			}

			:root[data-theme="dark"]
				.aplayer
				.aplayer-info
				.aplayer-controller
				.aplayer-bar-wrap
				.aplayer-bar
				.aplayer-played,
			:root[data-theme="dark"]
				.aplayer
				.aplayer-info
				.aplayer-controller
				.aplayer-volume-wrap
				.aplayer-volume-bar-wrap
				.aplayer-volume-bar {
				background: hsl(var(--theme-accent));
			}

			:root[data-theme="dark"]
				.aplayer
				.aplayer-info
				.aplayer-controller
				.aplayer-bar-wrap
				.aplayer-bar
				.aplayer-thumb {
				background: hsl(var(--theme-accent));
				box-shadow: 0 0 0 2px hsl(var(--theme-bg));
			}

			:root[data-theme="dark"] .aplayer .aplayer-info .aplayer-music .aplayer-title {
				color: hsl(var(--theme-text));
			}

			:root[data-theme="dark"] .aplayer .aplayer-info .aplayer-music .aplayer-author,
			:root[data-theme="dark"] .aplayer .aplayer-info .aplayer-controller .aplayer-time,
			:root[data-theme="dark"] .aplayer .aplayer-list ol li {
				color: hsl(var(--theme-text) / 0.72);
			}

			:root[data-theme="dark"] .aplayer .aplayer-icon path {
				fill: hsl(var(--theme-text));
			}

			:root[data-theme="dark"] .aplayer .aplayer-icon:hover path {
				fill: hsl(var(--theme-accent));
			}

			:root[data-theme="dark"] .aplayer .aplayer-list {
				background: hsl(var(--theme-muted));
				overflow-y: auto;
				overscroll-behavior: contain;
			}

			:root[data-theme="dark"] .aplayer .aplayer-list ol li {
				border-top-color: hsl(var(--theme-border));
			}

			:root[data-theme="dark"] .aplayer .aplayer-list ol li:hover,
			:root[data-theme="dark"] .aplayer .aplayer-list ol li.aplayer-list-light {
				background: hsl(var(--theme-bg) / 0.9);
				color: hsl(var(--theme-text));
			}

			/* Hide the lyric panel to avoid the extra gradient strip in article embeds. */
			.aplayer .aplayer-lrc,
			.aplayer .aplayer-lrc:before,
			.aplayer .aplayer-lrc:after {
				display: none !important;
			}

			.aplayer.aplayer-withlrc .aplayer-pic {
				height: 66px !important;
				width: 66px !important;
			}

			.aplayer.aplayer-withlrc .aplayer-info {
				margin-left: 66px !important;
				height: 66px !important;
				padding: 14px 7px 0 10px !important;
			}

			/* Show only the first 5 tracks in album embeds. */
			.aplayer .aplayer-list,
			.aplayer .aplayer-list ol {
				max-height: 160px !important;
				overflow: hidden !important;
			}

			.aplayer .aplayer-list ol li:nth-child(n + 6) {
				display: none !important;
			}
		</style>
	</head>
	<body
		class="mx-auto flex min-h-screen max-w-5xl flex-col bg-bgColor px-4 pb-8 pt-20 font-body text-lg font-normal leading-relaxed text-textColor antialiased selection:bg-accent/30 selection:text-accent sm:px-12"
	>
		<ThemeProvider />
		<SkipLink />

		<!-- Academia texture overlay (lightweight CSS noise) -->
		<div class="academia-texture" aria-hidden="true"></div>

		<!-- Academia vignette -->
		<div class="academia-vignette" aria-hidden="true"></div>

		<Header />
		<main id="main">
			<slot />
		</main>
		<Footer />
		<script is:inline>
			(() => {
				function bindAlbumTitle(player) {
					if (!(player instanceof HTMLElement) || player.dataset.albumTitleBound === "true") return;

					const albumTitle =
						player.dataset.albumTitle?.trim() ||
						(() => {
							let current = player.previousElementSibling;
							while (current) {
								if (/^H[1-6]$/.test(current.tagName)) return current.textContent?.trim() || "";
								current = current.previousElementSibling;
							}
							return "";
						})();

					if (!albumTitle) return;

					player.dataset.albumTitleBound = "true";

					const applyAlbumTitle = () => {
						const title = player.querySelector(".aplayer-title");
						if (title && title.textContent !== albumTitle) {
							title.textContent = albumTitle;
						}
					};

					const observer = new MutationObserver(applyAlbumTitle);
					observer.observe(player, {
						childList: true,
						characterData: true,
						subtree: true,
					});

					applyAlbumTitle();
				}

				function initAlbumTitles() {
					document.querySelectorAll("meting-js[type='album']").forEach(bindAlbumTitle);
				}

				initAlbumTitles();

				if (window.__fftAlbumTitleBound !== "true") {
					window.__fftAlbumTitleBound = "true";
					document.addEventListener("astro:page-load", initAlbumTitles);
					document.addEventListener("meting:ready", initAlbumTitles);
				}
			})();
		</script>
	</body>
</html>
