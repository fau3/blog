---
import { type CollectionEntry, render } from "astro:content";
import Comments from "@/components/Comment.astro";
import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import { getEntryDescription } from "@/utils/content-preview";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post"> | CollectionEntry<"postEn">;
}

const { post } = Astro.props;
const { ogImage, title, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings } = await render(post);
const hasMeting = post.body?.includes("<meting-js") ?? false;
const description = getEntryDescription({
	body: post.body ?? "",
	description: post.data.description,
	maxLength: 160,
});
---

<BaseLayout
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		title,
	}}
	hasMeting={hasMeting}
>
	<div class="gap-x-10 lg:flex lg:items-start">
		{!!headings.length && <TOC headings={headings} />}
		<article class="flex-grow break-words" data-pagefind-body>
			<div id="blog-hero"><Masthead content={post} /></div>
			<div
				class="prose prose-lg prose-cactus mt-12 max-w-2xl prose-headings:font-heading prose-headings:font-normal prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent sm:prose-headings:before:content-['#'] sm:prose-th:before:content-none"
			>
				<slot />
				<WebMentions />
			</div>
		</article>
	</div>
	<Comments />
	<button
		aria-label="Back to Top"
		class="z-90 btn-brass fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded border-2 border-transparent opacity-0 transition-all duration-500 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
		><svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>
<script is:inline>
	(() => {
		const initBackToTop = () => {
			const scrollBtn = document.getElementById("to-top-btn");
			const targetHeader = document.getElementById("blog-hero");

			if (!scrollBtn || !targetHeader || scrollBtn.dataset.bound === "true") return;

			scrollBtn.dataset.bound = "true";
			scrollBtn.addEventListener("click", () => {
				document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
			});

			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					scrollBtn.dataset.show = String(!entry.isIntersecting);
				});
			});

			observer.observe(targetHeader);
		};

		initBackToTop();

		if (!window.__fftBackToTopBound) {
			window.__fftBackToTopBound = true;
			document.addEventListener("astro:page-load", initBackToTop);
		}
	})();
</script>
