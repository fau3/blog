---
import friends from "@/data/friendLinks.json";

---

<div class="flex flex-nowrap items-baseline gap-x-4 overflow-x-auto">
	{
		friends.map(({ name, link }) => (
			<a
				href={link}
				target="_blank"
				rel="noopener noreferrer"
				class="cactus-link font-display text-xs uppercase tracking-[0.18em] text-accent hover:text-accent-2 whitespace-nowrap"
			>
				{name}
			</a>
		))
	}
</div>
