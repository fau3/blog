# Container image
GOTOSOCIAL_IMAGE=docker.io/superseriousbusiness/gotosocial:latest

# Server timezone
TZ=Asia/Singapore

# Public domain layout
GTS_HOST=social.fft.im
GTS_ACCOUNT_DOMAIN=fft.im
GTS_PROTOCOL=https

# Docker networking
# In Docker we bind GoToSocial to 0.0.0.0 inside the container,
# but publish it only on 127.0.0.1 on the host.
GTS_BIND_ADDRESS=0.0.0.0
GTS_PORT=8080
HOST_BIND_PORT=8080

# Storage
GTS_DB_TYPE=sqlite
GTS_DB_SQLITE_ADDRESS=/gotosocial/storage/sqlite.db
GTS_STORAGE_BACKEND=local
GTS_STORAGE_LOCAL_BASE_PATH=/gotosocial/storage

# Instance behavior
GTS_ACCOUNTS_REGISTRATION_OPEN=false
GTS_LETSENCRYPT_ENABLED=false
GTS_LOG_LEVEL=info

# Adjust this if your Docker bridge gateway is not 172.17.0.1.
# If GoToSocial logs say your reverse proxy is untrusted, inspect
# `docker network inspect bridge` or your compose network and update it.
GTS_TRUSTED_PROXIES=127.0.0.1/32,::1,172.17.0.1/32
